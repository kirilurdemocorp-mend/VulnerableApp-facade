{
  "name": "facade-app",
  "version": "0.1.0",
  "private": true,
  "proxy": "http://localhost:80",
  "dependencies": {
    "@testing-library/jest-dom": "^5.12.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "prettier": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-scripts": "4.0.3",
    "rsuite": "^4.10.1",
    "typescript": "^5.0.0",
    "web-vitals": "^5.0.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test -u",
    "eject": "react-scripts eject",
    "pretty": "prettier --write \"./**/*.{js,jsx,tsx,css}\""
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "jest": {
    "collectCoverageFrom": [
        "<rootDir>/src/**/*.{js,ts,jsx,tsx}",
        "!<rootDir>/src/test/**",
        "!<rootDir>/src/interface/*",
        "!<rootDir>/src/react-app-env.d.ts"
    ]
  },
  "devDependencies": {
    "ts-node": "^10.7.0"
  }
}
